{
  // Build config for @typedstandards/verify-core. The source is browser-safe and
  // imports siblings with explicit `.ts` extensions (the convention it was
  // authored under in civic-ai-tools-website). `rewriteRelativeImportExtensions`
  // converts those to `.js` on emit so the published ESM resolves under plain
  // Node, bundlers, and the browser alike — one source, no per-target rewrite.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "declaration": true,
    // No source/declaration maps: we ship dist only (not src), so maps would
    // dangle. The .d.ts files carry full type information on their own.
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "dist", "node_modules"]
}
